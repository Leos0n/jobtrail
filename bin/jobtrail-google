#!/usr/bin/env python3
"""Connect a Google Sheet to JobTrail and sync it in (read-only, one-way).

One-time setup (see docs/GOOGLE_SHEETS.md):
  1. Create a free Google Cloud project, enable the Google Sheets API.
  2. Create an OAuth "Desktop app" client; download credentials.json.
  3. Put it at data/google/credentials.json.

Then:
  ./bin/jobtrail-google connect
  ./bin/jobtrail-google tabs --sheet "https://docs.google.com/spreadsheets/d/<ID>/edit"
  ./bin/jobtrail-google sync --sheet "<url>" --tabs "Applications,Older applications" [--dry-run]
  ./bin/jobtrail-google sync            # re-sync using saved config (capture new rows)
  ./bin/jobtrail-google sync --reset    # clear old sheet rows + re-import fresh
                                        #   (fixes duplicate/incorrect counts; backs up first)
  ./bin/jobtrail-google sync --wipe     # clear ALL jobs + re-import (full reset;
                                        #   use if --reset still miscounts; backs up first)
  ./bin/jobtrail-google status
"""
import argparse
import csv
import json
import os
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from webapp import backup, gauth, gsheets, sheets_map  # noqa: E402
from webapp.db import Database  # noqa: E402

GDIR = ROOT / "data" / "google"
CREDS = GDIR / "credentials.json"
TOKEN = GDIR / "token.json"
CONFIG = GDIR / "config.json"
DB = ROOT / "data" / "jobs.db"
BACKUPS_DIR = ROOT / "data" / "backups"


def load_config():
    return json.loads(CONFIG.read_text()) if CONFIG.is_file() else {}


def save_config(cfg):
    GDIR.mkdir(parents=True, exist_ok=True)
    CONFIG.write_text(json.dumps(cfg, indent=2))


def need_token():
    if not gauth.is_connected(TOKEN):
        sys.exit("Not connected. Run: ./bin/jobtrail-google connect")
    return gauth.access_token(TOKEN)


def cmd_connect(args):
    if not CREDS.is_file():
        sys.exit(f"Missing {CREDS}. See docs/GOOGLE_SHEETS.md to create credentials.json.")
    gauth.run_connect(CREDS, TOKEN)
    print("\nConnected. Your refresh token is stored locally at", TOKEN)
    print("(git-ignored, user-only permissions — it never leaves this machine).")


def cmd_tabs(args):
    token = need_token()
    sid = gsheets.spreadsheet_id(args.sheet or load_config().get("spreadsheet_url") or "")
    tabs = gsheets.list_tabs(sid, token)
    print("Tabs in this spreadsheet:")
    for t in tabs:
        print("  -", t)


def _read_export(path):
    """Read a downloaded sheet tab (CSV or TSV) into a grid of cell values."""
    p = Path(path)
    if not p.is_file():
        sys.exit(f"Export file not found: {path}")
    delim = "\t" if p.suffix.lower() in (".tsv", ".tab") else ","
    with p.open(newline="", encoding="utf-8-sig") as f:
        return p.stem, [list(row) for row in csv.reader(f, delimiter=delim)]


def cmd_sync(args):
    cfg = load_config()
    all_jobs, warnings = [], []
    sheet = sid = None

    if args.from_file:
        # Offline resync from a downloaded export (File > Download > CSV/TSV in
        # Sheets), one file per tab. No Google OAuth needed; same parser + import
        # path as a live sync, so counts come out identical.
        for path in [p.strip() for p in args.from_file.split(",") if p.strip()]:
            tab, values = _read_export(path)
            res = sheets_map.values_to_jobs(values, default_status=args.status, tab=tab)
            print(f"  {tab!r} ({path}): {len(res['jobs'])} job row(s)")
            all_jobs.extend(res["jobs"])
            warnings.extend(res["warnings"])
    else:
        token = need_token()
        sheet = args.sheet or cfg.get("spreadsheet_url")
        if not sheet:
            sys.exit("No sheet configured. Pass --sheet <url> the first time, "
                     "or use --from-file <export.csv> for an offline resync.")
        sid = gsheets.spreadsheet_id(sheet)
        tabs = [t.strip() for t in args.tabs.split(",")] if args.tabs else cfg.get("tabs")
        if not tabs:
            sys.exit("No tabs selected. Pass --tabs \"Tab A,Tab B\" the first time "
                     "(use the 'tabs' command to list them).")
        for tab in tabs:
            values, links = gsheets.read_tab_with_links(sid, tab, token)
            res = sheets_map.values_to_jobs(values, default_status=args.status, tab=tab, links=links)
            print(f"  {tab!r}: {len(res['jobs'])} job row(s)")
            all_jobs.extend(res["jobs"])
            warnings.extend(res["warnings"])
    for w in warnings:
        print("  !", w, file=sys.stderr)

    if args.dry_run:
        db = Database(str(DB))
        new = sum(1 for j in all_jobs if not db.find_by_key(j.get("url", ""), j.get("job_key")))
        db.close()
        print(f"\n[dry run] {len(all_jobs)} rows · {new} new, {len(all_jobs)-new} already present. Nothing written.")
        return

    db = Database(str(DB))
    removed = 0
    if args.wipe or args.reset:
        # Back up first, then clear rows so a fresh import produces exact counts.
        # --wipe clears EVERY job (handles stale rows from syncs that predate
        # source tagging); --reset clears only sheet-sourced rows.
        if DB.is_file():
            backup.snapshot(str(DB), str(BACKUPS_DIR), reason="pre-wipe" if args.wipe else "pre-reset")
        removed = db.clear_jobs() if args.wipe else db.delete_by_source("google-sheet")
    result = db.import_jobs(all_jobs)
    db.close()
    cfg.update({
        "default_status": args.status,
        "last_sync": time.strftime("%Y-%m-%dT%H:%M:%S"),
        "last_added": result["added"],
        "last_total": len(all_jobs),
    })
    if sheet:  # live sync — remember the source; an offline --from-file keeps it
        cfg.update({"spreadsheet_id": sid, "spreadsheet_url": sheet, "tabs": tabs})
    save_config(cfg)
    if args.wipe:
        print(f"\nWiped + resynced. Cleared {removed} job(s), imported {result['added']} fresh "
              f"(backup saved to data/backups).")
    elif args.reset:
        print(f"\nReset sync. Removed {removed} old sheet row(s), imported {result['added']} fresh "
              f"(backup saved to data/backups).")
    else:
        print(f"\nSynced. Added {result['added']} new job(s); skipped {result['skipped']} already present.")


def cmd_status(args):
    print("Connected:", gauth.is_connected(TOKEN))
    cfg = load_config()
    if cfg:
        print("Spreadsheet:", cfg.get("spreadsheet_url"))
        print("Tabs:", ", ".join(cfg.get("tabs", [])) or "—")
        print("Last sync:", cfg.get("last_sync", "never"),
              f"(added {cfg.get('last_added', 0)} of {cfg.get('last_total', 0)} rows)")
    else:
        print("No sheet configured yet.")


def main():
    ap = argparse.ArgumentParser(prog="jobtrail-google", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)
    sub.add_parser("connect").set_defaults(func=cmd_connect)
    t = sub.add_parser("tabs"); t.add_argument("--sheet"); t.set_defaults(func=cmd_tabs)
    s = sub.add_parser("sync")
    s.add_argument("--sheet"); s.add_argument("--tabs"); s.add_argument("--status", default=None,
                   help="Default status for rows whose status cell is blank (e.g. applied).")
    s.add_argument("--from-file", metavar="EXPORT.csv[,EXPORT2.csv]",
                   help="Offline resync from downloaded sheet export(s) (CSV/TSV, "
                        "one per tab) instead of the live Google API. Combine with "
                        "--wipe for a full clean reimport without OAuth.")
    s.add_argument("--dry-run", action="store_true")
    s.add_argument("--reset", action="store_true",
                   help="Clear previously sheet-imported rows and re-import fresh "
                        "(fixes duplicate/incorrect counts). Backs up first.")
    s.add_argument("--wipe", action="store_true",
                   help="Clear ALL jobs (full reset) and re-import from the sheet. "
                        "Use if --reset still leaves wrong counts. Backs up first.")
    s.set_defaults(func=cmd_sync)
    sub.add_parser("status").set_defaults(func=cmd_status)
    args = ap.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
