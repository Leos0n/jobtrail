#!/usr/bin/env python3
"""Diagnose why Google Sheets sync isn't importing new rows.

Read-only: reads your configured sheet, parses it exactly like the importer
does, and reports — per tab — how many rows parse into jobs and how many the
importer would treat as NEW vs already-present. Writes nothing to your DB.

Run from the repo root:  ./bin/jobtrail-sheet-debug
"""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from webapp import gauth, gsheets, gsync, sessions, sheets_map  # noqa: E402
from webapp.db import Database  # noqa: E402

DB_PATH = ROOT / "data" / "jobs.db"


def main() -> int:
    cfg = gsync._config()
    if not gauth.is_connected(gsync.TOKEN):
        print("Not connected. Run bin/jobtrail-google first.")
        return 1
    if not cfg.get("spreadsheet_url") or not cfg.get("tabs"):
        print("No sheet configured (spreadsheet_url / tabs missing).")
        return 1

    print(f"Spreadsheet : {cfg['spreadsheet_url']}")
    print(f"Synced tabs : {cfg['tabs']}")

    try:
        token = gauth.access_token(gsync.TOKEN)
    except gauth.AuthError as exc:
        print(f"\nAUTH PROBLEM: {exc}")
        return 1

    sid = gsheets.spreadsheet_id(cfg["spreadsheet_url"])
    all_tabs = gsheets.list_tabs(sid, token)
    print(f"All tabs    : {all_tabs}")
    missing = [t for t in all_tabs if t not in cfg["tabs"]]
    if missing:
        print(f"  NOTE: these tabs exist but are NOT synced: {missing}")

    db = Database(str(DB_PATH))
    all_db = db.list_jobs()
    db_sheet_rows = [j for j in all_db if j.get("source") == "google-sheet"]
    print(f"Jobs in DB  : {len(all_db)} ({len(db_sheet_rows)} from the sheet)\n")

    def already(job):
        key = job.get("job_key")
        if key:
            return db.conn.execute("SELECT 1 FROM jobs WHERE job_key = ?", [key]).fetchone()
        return db.find_by_key(job.get("url", ""), None)

    grand_parsed = grand_new = grand_links = 0
    parsed_by_day = {}
    all_parsed = []
    for tab in cfg["tabs"]:
        values, links = gsheets.read_tab_with_links(sid, tab, token)
        res = sheets_map.values_to_jobs(
            values, default_status=cfg.get("default_status"), tab=tab, links=links)
        jobs = res["jobs"]
        all_parsed.extend(jobs)
        layout = res.get("mapping", {}).get("layout", "table")
        new = [j for j in jobs if not already(j)]
        with_link = [j for j in jobs if (j.get("url") or "").startswith("http")]
        grand_parsed += len(jobs)
        grand_new += len(new)
        grand_links += len(with_link)
        for j in jobs:
            d = j.get("date_applied") or "(no date)"
            parsed_by_day[d] = parsed_by_day.get(d, 0) + 1
        print(f"Tab '{tab}': {len(values)} rows -> {len(jobs)} parsed jobs "
              f"(layout={layout}), {len(new)} NEW, {len(with_link)} with real links")
        for w in res.get("warnings", []):
            print(f"    warning: {w}")
        print("    most recent parsed rows:")
        for j in jobs[-5:]:
            print(f"      - {j.get('company')} | {j.get('title')} | "
                  f"applied={j.get('date_applied')} | url={j.get('url')}")
        print()

    # Compare what the sheet SAYS per day against what's actually in the DB —
    # a mismatch means stale duplicates (over/undercount) that --reset fixes.
    db_by_day = {}
    for j in db_sheet_rows:
        d = j.get("date_applied") or "(no date)"
        db_by_day[d] = db_by_day.get(d, 0) + 1
    mismatched = {d: (db_by_day.get(d, 0), parsed_by_day.get(d, 0))
                  for d in set(db_by_day) | set(parsed_by_day)
                  if db_by_day.get(d, 0) != parsed_by_day.get(d, 0)}
    if mismatched:
        print("DAY-COUNT MISMATCH (DB vs sheet) — stale duplicates present:")
        for d in sorted(mismatched, reverse=True)[:12]:
            indb, insheet = mismatched[d]
            print(f"    {d}: DB has {indb}, sheet says {insheet}")
        print("  Fix with a one-time clean re-import (backs up first):")
        print("    ./bin/jobtrail-google sync --reset\n")

    summaries = sessions.summarize(all_parsed)
    if summaries:
        print(sessions.format_text(summaries))
        print()

    db.close()
    print(f"TOTAL: parsed={grand_parsed}  new={grand_new}  with-real-links={grand_links}")
    if grand_links < grand_parsed:
        print(f"  NOTE: {grand_parsed - grand_links} row(s) have no recoverable link "
              "(cell isn't actually hyperlinked in the sheet).")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
